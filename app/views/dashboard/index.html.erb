                            <span class="stat-value">3</span>
                        </div>
                        <div class="integration-stat">
                            <span class="stat-label">Tickets Created</span>
                            <span class="stat-value">128</span>
                        </div>
                        <div class="integration-stat">
                            <span class="stat-label">Auto-Closed</span>
                            <span class="stat-value">86</span>
                        </div>
                        <ul class="repo-list">
                            <li>GRC Spend Management</li>
                            <li>Workforce Solutions</li>
                            <li>Provider Platform</li>
                        </ul>
                    </div>
                    <div class="integration-card-footer">
                        <button class="btn btn-secondary btn-sm">Configure</button>
                    </div>
                </div>

                <div class="integration-card">
                    <div class="integration-card-header">
                        <span class="integration-logo">📊</span>
                        <h3>Observability</h3>
                        <span class="status-badge success">Connected</span>
                    </div>
                    <div class="integration-card-body">
                        <div class="integration-stat">
                            <span class="stat-label">Datadog</span>
                            <span class="stat-value">✓</span>
                        </div>
                        <div class="integration-stat">
                            <span class="stat-label">AWS CloudWatch</span>
                            <span class="stat-value">✓</span>
                        </div>
                        <div class="integration-stat">
                            <span class="stat-label">Rollbar</span>
                            <span class="stat-value">✓</span>
                        </div>
                        <div class="integration-stat">
                            <span class="stat-label">New Relic</span>
                            <span class="stat-value">✓</span>
                        </div>
                        <div class="integration-stat">
                            <span class="stat-label">Sentry</span>
                            <span class="stat-value">✓</span>
                        </div>
                        <p class="integration-description">
                            Real-time monitoring of errors, logs, and performance metrics across all environments.
                        </p>
                    </div>
                    <div class="integration-card-footer">
                        <button class="btn btn-secondary btn-sm">Configure</button>
                    </div>
                </div>

                <div class="integration-card">
                    <div class="integration-card-header">
                        <span class="integration-logo">💬</span>
                        <h3>Microsoft Teams</h3>
                        <span class="status-badge success">Connected</span>
                    </div>
                    <div class="integration-card-body">
                        <div class="integration-stat">
                            <span class="stat-label">Channels</span>
                            <span class="stat-value">8</span>
                        </div>
                        <div class="integration-stat">
                            <span class="stat-label">Notifications Sent</span>
                            <span class="stat-value">342</span>
                        </div>
                        <div class="integration-stat">
                            <span class="stat-label">Response Rate</span>
                            <span class="stat-value">94%</span>
                        </div>
                        <p class="integration-description">
                            Automatic PR review requests and incident notifications sent to developers.
                        </p>
                    </div>
                    <div class="integration-card-footer">
                        <button class="btn btn-secondary btn-sm">Configure</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Projects Tab -->
        <div class="tab-content" id="projects-tab">
            <div class="projects-header">
                <h2>Project Management</h2>
                <button class="btn btn-primary" onclick="openCreateProject()">
                    <span class="btn-icon">➕</span>
