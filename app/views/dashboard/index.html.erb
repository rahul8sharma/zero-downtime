        <!-- Activity Tab -->
        <div class="tab-content" id="activity-tab">
            <div class="activity-feed" id="activity-feed">
                <!-- Activity logs are now on the dedicated activity page -->
            </div>
        </div>

        <!-- Analytics Tab -->
        <div class="tab-content" id="analytics-tab">
            <h2 class="section-title">📈 Analytics & Insights</h2>

            <div class="analytics-grid">
                <div class="analytics-card">
                    <h3>Incident Trends (Last 30 Days)</h3>
                    <div class="chart-placeholder">
                        <div class="trend-line">
                            <div class="trend-bar" style="height: 60%"></div>
                            <div class="trend-bar" style="height: 45%"></div>
                            <div class="trend-bar" style="height: 70%"></div>
