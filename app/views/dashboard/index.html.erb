<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Header -->
    <header class="header">
        <div class="header-content">
            <div class="logo">
                <%= image_tag "symplr-logo.svg", alt: "symplr", class: "logo-img" %>
                <div class="logo-divider"></div>
                <div class="logo-text">
                    <h1>Zero Downtime</h1>
                    <p>AI-Powered DevOps Automation Platform</p>
                </div>
            </div>
            <div class="header-actions">
                <div class="project-selector">
                    <label for="project-select">Project:</label>
                    <select id="project-select" onchange="switchProject(this.value)">
                        <option value="all">All Projects</option>
                        <% @projects.each_with_index do |project, index| %>
                          <option value="<%= project.id %>" <%= 'selected' if index == 0 %>><%= project.name %></option>
                        <% end %>
                    </select>
                    <%= link_to new_project_path, class: "btn btn-icon-only", title: "Create New Project", style: "text-decoration: none;" do %>
                        <span>➕</span>
                    <% end %>
                    <%= link_to projects_path, class: "btn btn-icon-only", title: "Manage Projects", style: "text-decoration: none;" do %>
                        <span>⚙️</span>
                    <% end %>
                </div>
                <button class="btn btn-secondary" onclick="openGuide()">
                    <span class="btn-icon">📖</span>
                    How It Works
                </button>
                <button class="btn btn-primary" onclick="startDemo()">
                    <span class="btn-icon">▶️</span>
                    Start Live Demo
                </button>
                <div class="status-indicator">
                    <span class="status-dot pulse"></span>
                    <span>Monitoring Active</span>
                </div>
            </div>
        </div>
    </header>

    <!-- Sidebar Navigation -->
    <aside class="sidebar" id="sidebar">
        <button class="sidebar-toggle" onclick="toggleSidebar()">
            <span>☰</span>
        </button>
        <nav class="sidebar-nav">
            <div class="sidebar-section">
                <div class="sidebar-section-title">MAIN</div>
                <%= link_to dashboard_index_path, class: "sidebar-item #{controller_name == 'dashboard' && action_name == 'index' ? 'active' : ''}" do %>
                    <span class="sidebar-icon">📊</span>
                    <span class="sidebar-label">Dashboard</span>
                <% end %>
                <a href="#" class="sidebar-item" onclick="switchTab('incidents')">
                    <span class="sidebar-icon">🔥</span>
                    <span class="sidebar-label">Live Incidents</span>
                    <span class="sidebar-badge">6</span>
                </a>
                <%= link_to dashboard_analytics_path, class: "sidebar-item #{action_name == 'analytics' ? 'active' : ''}" do %>
                    <span class="sidebar-icon">📈</span>
                    <span class="sidebar-label">Analytics</span>
                <% end %>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-section-title">MANAGEMENT</div>
                <%= link_to dashboard_projects_page_path, class: "sidebar-item #{action_name == 'projects_page' ? 'active' : ''}" do %>
                    <span class="sidebar-icon">📁</span>
                    <span class="sidebar-label">Projects</span>
                <% end %>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-section-title">MONITORING</div>
                <%= link_to dashboard_activity_path, class: "sidebar-item #{action_name == 'activity' ? 'active' : ''}" do %>
                    <span class="sidebar-icon">📝</span>
                    <span class="sidebar-label">Activity Log</span>
                <% end %>
                <%= link_to dashboard_logs_explorer_path, class: "sidebar-item #{action_name == 'logs_explorer' ? 'active' : ''}" do %>
                    <span class="sidebar-icon">🔍</span>
                    <span class="sidebar-label">Logs Explorer</span>
                <% end %>
                <%= link_to dashboard_alerts_path, class: "sidebar-item #{action_name == 'alerts' ? 'active' : ''}" do %>
                    <span class="sidebar-icon">🔔</span>
                    <span class="sidebar-label">Alerts</span>
                <% end %>
                <%= link_to dashboard_alert_rules_path, class: "sidebar-item #{action_name == 'alert_rules' ? 'active' : ''}" do %>
                    <span class="sidebar-icon">📋</span>
                    <span class="sidebar-label">Alert Rules</span>
                <% end %>
                <%= link_to dashboard_reports_path, class: "sidebar-item #{action_name == 'reports' ? 'active' : ''}" do %>
                    <span class="sidebar-icon">📄</span>
                    <span class="sidebar-label">Reports</span>
                <% end %>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-section-title">SETTINGS</div>
                <%= link_to dashboard_settings_path, class: "sidebar-item #{action_name == 'settings' ? 'active' : ''}" do %>
                    <span class="sidebar-icon">⚙️</span>
                    <span class="sidebar-label">Settings</span>
                <% end %>
            </div>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="main-content" id="main-content">
        <!-- Dashboard Tab -->
        <div class="tab-content active" id="dashboard-tab">
            <!-- Key Metrics -->
            <div class="metrics-grid">
                <div class="metric-card">
                    <div class="metric-header">
                        <span class="metric-icon">⚡</span>
                        <span class="metric-label">MTTR</span>
                    </div>
                    <div class="metric-value">15 min</div>
                    <div class="metric-change positive">↓ 90% vs manual (2-4 hrs)</div>
                </div>

                <div class="metric-card">
                    <div class="metric-header">
                        <span class="metric-icon">🎯</span>
                        <span class="metric-label">Auto-Fixed Today</span>
                    </div>
                    <div class="metric-value">12 / 18</div>
                    <div class="metric-change positive">67% success rate</div>
                </div>

                <div class="metric-card">
                    <div class="metric-header">
                        <span class="metric-icon">💰</span>
                        <span class="metric-label">Cost Savings</span>
                    </div>
                    <div class="metric-value">$117K</div>
                    <div class="metric-change positive">per year</div>
                </div>

                <div class="metric-card">
                    <div class="metric-header">
                        <span class="metric-icon">👥</span>
                        <span class="metric-label">Available Devs</span>
                    </div>
                    <div class="metric-value">3 / 8</div>
                    <div class="metric-change neutral">37% capacity</div>
                </div>
            </div>

            <!-- Main Dashboard Grid -->
            <div class="dashboard-grid">
                <!-- Recent Incidents -->
                <div class="panel">
                    <div class="panel-header">
                        <h2>🔥 Active Incidents</h2>
                        <span class="badge badge-critical"><%= @incidents.where(severity: 'critical').count %> Critical</span>
                    </div>
                    <div class="panel-content" id="dashboard-incidents">
                        <% if @incidents.any? %>
                            <% @incidents.each do |incident| %>
                                <div class="incident-card">
                                    <div class="incident-card-header">
                                        <div>
                                            <div class="incident-title"><%= incident.title %></div>
                                            <div class="incident-id">
                                                <%= incident.project.name %> • <%= incident.service || 'Unknown Service' %>
                                            </div>
                                        </div>
                                        <span class="status-badge <%= incident.status %>"><%= incident.status %></span>
                                    </div>
                                    <div class="incident-meta">
                                        <span>🔥 <%= incident.severity %></span>
                                        <span>⏰ <%= time_ago_in_words(incident.created_at) %> ago</span>
                                        <% if incident.source %>
                                            <span>📄 <%= incident.source %></span>
                                        <% end %>
                                    </div>
                                </div>
                            <% end %>
                        <% else %>
                            <div class="empty-state">
                                <div class="empty-icon">✅</div>
                                <p>No active incidents</p>
                                <p style="font-size: 0.875rem; color: #6C757D; margin-top: 8px;">
                                    Click "Sync Datadog Errors" to fetch latest errors
                                </p>
                            </div>
                        <% end %>
                    </div>
                </div>

                <!-- AI Analysis -->
                <div class="panel">
                    <div class="panel-header">
                        <h2>🧠 AI Analysis Pipeline</h2>
                    </div>
                    <div class="panel-content">
                        <div class="pipeline-stage">
                            <div class="stage-indicator active"></div>
                            <div class="stage-content">
                                <h4>1. Issue Detection</h4>
                                <p>Monitoring logs, errors, performance metrics</p>
                                <span class="stage-status">✅ Active</span>
                            </div>
                        </div>
                        <div class="pipeline-stage">
                            <div class="stage-indicator active"></div>
                            <div class="stage-content">
                                <h4>2. AI Diagnosis</h4>
                                <p>Analyzing code, commits, and context</p>
                                <span class="stage-status">⏳ Processing</span>
                            </div>
                        </div>
                        <div class="pipeline-stage">
                            <div class="stage-indicator"></div>
                            <div class="stage-content">
                                <h4>3. Auto-Fix Generation</h4>
                                <p>Creating PR with fix code</p>
                                <span class="stage-status">⏸️ Waiting</span>
                            </div>
                        </div>
                        <div class="pipeline-stage">
                            <div class="stage-indicator"></div>
                            <div class="stage-content">
                                <h4>4. Team Assignment</h4>
                                <p>Finding available developer for review</p>
                                <span class="stage-status">⏸️ Waiting</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Integration Status -->
                <div class="panel">
                    <div class="panel-header">
                        <h2>🔗 Connected Systems</h2>
                    </div>
                    <div class="panel-content">
                        <div class="integration-item">
                            <span class="integration-icon">📦</span>
                            <div class="integration-info">
                                <strong>GitHub</strong>
                                <span>5 repositories monitored</span>
                            </div>
                            <span class="status-badge success">Connected</span>
                        </div>
                        <div class="integration-item">
                            <span class="integration-icon">📋</span>
                            <div class="integration-info">
                                <strong>Azure DevOps</strong>
                                <span>3 projects synced</span>
                            </div>
                            <span class="status-badge success">Connected</span>
                        </div>
                        <div class="integration-item">
                            <span class="integration-icon">📊</span>
                            <div class="integration-info">
                                <strong>Datadog</strong>
                                <span>Real-time metrics</span>
                            </div>
                            <span class="status-badge success">Connected</span>
                        </div>
                        <div class="integration-item">
                            <span class="integration-icon">🐛</span>
                            <div class="integration-info">
                                <strong>Rollbar</strong>
                                <span>Error tracking</span>
                            </div>
                            <span class="status-badge success">Connected</span>
                        </div>
                        <div class="integration-item">
                            <span class="integration-icon">💬</span>
                            <div class="integration-info">
                                <strong>Microsoft Teams</strong>
                                <span>Notifications enabled</span>
                            </div>
                            <span class="status-badge success">Connected</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Incidents Tab -->
        <div class="tab-content" id="incidents-tab">
            <div class="incidents-header">
                <div class="filters">
                    <button class="filter-btn active" onclick="filterIncidents('all')">All (18)</button>
                    <button class="filter-btn" onclick="filterIncidents('critical')">Critical (3)</button>
                    <button class="filter-btn" onclick="filterIncidents('analyzing')">Analyzing (5)</button>
                    <button class="filter-btn" onclick="filterIncidents('fixed')">Fixed (10)</button>
                </div>
                <input type="text" class="search-input" placeholder="Search incidents..." onkeyup="searchIncidents(this.value)">
            </div>
            <div class="incidents-list" id="incidents-list">
                <!-- Populated by JS -->
            </div>
        </div>

