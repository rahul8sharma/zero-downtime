<%= render 'shared/header_sidebar' %>
    <main class="main-content" id="main-content">
        <div class="tab-content" id="integrations-tab">
            <div class="integrations-grid">
                <div class="integration-card">
                    <div class="integration-card-header">
                        <span class="integration-logo">📦</span>
                        <h3>GitHub</h3>
                        <span class="status-badge success">Connected</span>
                    </div>
                    <div class="integration-card-body">
                        <div class="integration-stat">
                            <span class="stat-label">Repositories</span>
                            <span class="stat-value">5</span>
                        </div>
                        <div class="integration-stat">
                            <span class="stat-label">PRs Created</span>
                            <span class="stat-value">47</span>
                        </div>
                        <div class="integration-stat">
                            <span class="stat-label">PRs Merged</span>
                            <span class="stat-value">42</span>
                        </div>
