                            <li>symplr/grc-spend-greenlight</li>
                            <li>symplr/workforce-backend</li>
                            <li>symplr/api-gateway</li>
                            <li>symplr/mobile-app</li>
                            <li>symplr/data-pipeline</li>
                        </ul>
                    </div>
                    <div class="integration-card-footer">
                        <button class="btn btn-secondary btn-sm">Configure</button>
                    </div>
                </div>

                <div class="integration-card">
                    <div class="integration-card-header">
